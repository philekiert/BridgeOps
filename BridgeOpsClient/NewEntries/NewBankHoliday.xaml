<local:CustomWindow x:Class="BridgeOpsClient.NewBankHoliday"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BridgeOpsClient"
        xmlns:custom="clr-namespace:BridgeOpsClient.CustomControls"
        mc:Ignorable="d"
        Title="New Bank Holiday" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        Closed="Window_Closed">
    <Grid Margin="5 5 5 0">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Label Content="Date" Grid.Row="0" Grid.Column="0" x:Name="lblResourceName"
                   VerticalAlignment="Center" Margin="0 10 0 0" FontWeight="SemiBold"/>
            <DatePicker x:Name="dtp" Grid.Column="1" Margin="10 10 0 0"/>
            <Label Content="Notes" Grid.Row="1" Grid.Column="0" Margin="0 10 0 0"
                   VerticalAlignment="Top" FontWeight="SemiBold"/>
            <TextBox x:Name="txtNotes" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"
                         Margin="10,10,10,0" TextWrapping="Wrap" Width="300" Height="100"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>

        </Grid>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="0 0 10 0">
            <Button x:Name="btnAdd" Content="Add" Margin="10,15,0,15" HorizontalAlignment="Right"
                    Width="70" Click="btnAdd_Click" Style="{StaticResource primary-button}" Height="24"/>
            <Button x:Name="btnDelete" Content="Delete" Margin="10,15,0,15" HorizontalAlignment="Right"
                    Width="70" Click="btnDelete_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</local:CustomWindow>
